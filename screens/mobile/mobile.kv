<MobileImageColorPicker>:
    MDScrollView:
        pos_hint: {'top':1}
        MDBoxLayout:
            orientation:'vertical'
            adaptive_height:True         
            
            MDBoxLayout:
                orientation:'vertical'
                spacing:'10sp'
                padding:[dp(15), dp(15), dp(15), dp(15)]
                adaptive_height:True
                
                MDLabel:
                    text:'Main Colors'
                    font_size:dp(25)
                    bold:True
                    padding:[dp(15), 0,0,0]
                MDBoxLayout:
                    size_hint_y:None
                    height:dp(64)
                    spacing:'15sp'
                    padding:[dp(5), dp(5), dp(5), dp(5)]
                    ColorCard:
                        id:main_color_1
                        color:[0,0,1,1]
                    ColorCard:
                        id:main_color_2
                        color:[0,0,1,1]
                    ColorCard:
                        id:main_color_3
                        color:[0,0,1,1]
                    ColorCard:
                        id:main_color_4
                        color:[0,0,1,1]
                    ColorCard:
                        id:main_color_5
                        color:[0,0,1,1]
            
                ImageColor:
                    padding:[dp(25), dp(25), dp(25), dp(25)]
                    pos_hint:{'center_x':0.5}
                    size_hint_y:None
                    size_hint_x:None
                    height:self.Image_height
                    width:self.Image_width   
                    source:root.source

                MDRaisedButton:
                    text:'select image'
                    on_release:root.select_image()
                    pos_hint:{'center_x':0.5}
                

                MDBoxLayout:
                    orientation: 'vertical'
                    padding:[20, 30, 20, 20]
                    spacing:20
                    adaptive_height:True
                    ColorCodes:
                        color_label:root.rgb_color_label
                        color:root.rgb_color
                        declaration_lbl:'RGB'
                    ColorCodes:
                        color_label:root.hsv_color_label
                        color:root.hsv_color
                        declaration_lbl:'HSV'
                    ColorCodes:
                        color_label:root.hsl_color_label
                        color:root.hsl_color
                        declaration_lbl:'HLS'
                    ColorCodes:
                        color_label:root.hex_color_label
                        color:root.hex_color
                        declaration_lbl:'HEX'